// 1. Main Zone: Hardened & Read-Only
zone "internal" {
    type master;
    file "/var/lib/bind/db.internal";
    allow-query { "internal"; "home-services"; "dns-resolvers"; };
    allow-transfer { none; };
    update-policy {
        // GRANT <key-name> subdomain <restrict-to-this-name> <record-types>
        // This ONLY allows the key to add/delete TXT records 
        // that are subdomains of _acme-challenge.internal.
        grant "acme_dns-01" subdomain internal. TXT;
    };
};