acl "home-services" {
    192.168.4.0/24;
};

acl "internal" {
    192.168.4.0/24;
};

acl "dns-resolvers" {
    127.0.0.1;
    172.30.255.20; # Only AdGuard can ask for normal records
    172.30.255.40; # Step-CA needs to verify TXT records
};

acl "acme-updaters" {
    192.168.4.0/24; # The machines running your ACME clients
    172.30.255.0/24; # Step-CA needs to verify TXT records
};
