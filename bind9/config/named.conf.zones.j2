{% for zone_name, zone_records in dns.items() %}
zone "{{ zone_name }}" {
    type master;
    file "/var/lib/bind/db.{{ zone_name }}";
    allow-query { {% for acl_name in bind_acls.keys() %}"{{ acl_name }}"; {% endfor %}};
    allow-transfer { none; };
    update-policy {
        // --- core-certbot ---
        // The built-in ACME key can ONLY update the exact _acme-challenge
        // TXT records for domains managed by core certbot.
{% for d in certbot_domains %}
{% if d.endswith('.' ~ zone_name) or d.endswith(zone_name) %}
        grant "{{ tsig_primary_key_name }}" name _acme-challenge.{{ d }}. TXT;
{% endif %}
{% endfor %}

        // --- additional keys ---
        // Keys added by add-tsig-key.sh will appear below this line.
        // (managed outside of Ansible — do not remove this comment)
    };
};

{% endfor %}
