tls my-tls-settings {
    key-file "/etc/bind9/ssl/privkey.pem";
    cert-file "/etc/bind9/ssl/fullchain.pem";
    protocols { TLSv1.2; TLSv1.3; };
    ciphers "HIGH:!aNULL:!MD5";
};

{% if bind9_only | default(false) %}
// DoH endpoint — nginx terminates TLS and forwards plain HTTP to port {{ bind9_doh_port }}
http dns-over-https {
    endpoints { "/dns-query"; };
};
{% endif %}

