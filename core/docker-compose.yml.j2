services:
  nginx:
    image: nginx:latest
    container_name: nginx
    user: "{{ service_users.nginx.uid }}:{{ service_users.nginx.gid }}"
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,size=10m,uid={{ service_users.nginx.uid }},gid={{ service_users.nginx.gid }}
      - /var/cache/nginx:noexec,nosuid,size=50m,uid={{ service_users.nginx.uid }},gid={{ service_users.nginx.gid }}
      - /var/run:noexec,nosuid,size=5m,uid={{ service_users.nginx.uid }},gid={{ service_users.nginx.gid }}
      - /var/log/nginx:noexec,nosuid,size=5m,uid={{ service_users.nginx.uid }},gid={{ service_users.nginx.gid }}
    ports:
      - 80:80
      - 443:443
      - 53:53/tcp
      - 53:53/udp
      - 853:853/tcp
      - 389:389
      - 636:636
    volumes:
      - {{ target_base }}/nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - {{ target_base }}/certbot/etc/letsencrypt/live:/etc/letsencrypt/live:ro
      - {{ target_base }}/certbot/etc/letsencrypt/archive:/etc/letsencrypt/archive:ro
    networks:
      core_net:
        ipv4_address: "{{ ip_nginx }}"
        aliases:
          - "{{ url_nginx }}"
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:80/"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

  adguardhome:
    image: adguard/adguardhome:latest
    container_name: adguardhome
    user: "{{ service_users.adguard.uid }}:{{ service_users.adguard.gid }}"
    cap_add:
      - NET_BIND_SERVICE
    restart: unless-stopped
    entrypoint: ["/bin/sh", "-c", "update-ca-certificates 2>/dev/null; exec /opt/adguardhome/AdGuardHome --no-check-update -c /opt/adguardhome/conf/AdGuardHome.yaml -w /opt/adguardhome/work"]
    volumes:
      - {{ target_base }}/adguardhome/work:/opt/adguardhome/work
      - {{ target_base }}/adguardhome/config:/opt/adguardhome/conf
      - {{ target_base }}/certbot/etc/letsencrypt/live/{{ url_adguard }}:/etc/letsencrypt/live/{{ url_adguard }}:ro
      - {{ target_base }}/certbot/etc/letsencrypt/archive/{{ url_adguard }}:/etc/letsencrypt/archive/{{ url_adguard }}:ro
      - {{ target_base }}/stepca/data/certs/root_ca.crt:/usr/local/share/ca-certificates/internal-root.crt:ro
    networks:
      core_net:
        ipv4_address: "{{ ip_adguard }}"
        aliases:
          - "{{ url_adguard }}"
    environment:
      - TZ={{ system_timezone }}
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost:80/"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 15s

  bind9:
    image: ubuntu/bind9:latest
    container_name: bind9
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
      - SETUID
      - SETGID
      - CHOWN
    ports:
      - "{{ bind_dns_port }}:{{ bind_dns_port }}/tcp"
      - "{{ bind_dns_port }}:{{ bind_dns_port }}/udp"
    volumes:
      - {{ target_base }}/bind9/config:/etc/bind:ro
      - {{ target_base }}/bind9/var/lib/bind:/var/lib/bind
      - {{ target_base }}/bind9/var/log:/var/log
      - {{ target_base }}/bind9/var/cache/bind:/var/cache/bind
      - {{ target_base }}/bind9/ssl:/etc/bind9/ssl:ro
    # Remap the container's bind user to our UID:GID, then hand off
    # to the stock entrypoint which runs: named -u bind -g
    entrypoint: ["/bin/sh", "-c"]
    command:
      - |
        groupmod -g {{ service_users.bind.gid }} bind
        usermod  -u {{ service_users.bind.uid }} -g {{ service_users.bind.gid }} -d /nonexistent bind
        chown {{ service_users.bind.uid }}:{{ service_users.bind.gid }} /run/named /var/cache/bind
        exec docker-entrypoint.sh -c /etc/bind/named.conf
    networks:
      core_net:
        ipv4_address: "{{ ip_bind9 }}"
        aliases:
          - "{{ url_bind9 }}"
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "test -s /run/named/named.pid"]
      interval: 10s
      start_period: 10s
      timeout: 5s
      retries: 3

  step-ca:
    image: smallstep/step-ca:latest
    container_name: step-ca
    user: "{{ service_users.step.uid }}:{{ service_users.step.gid }}"
    restart: unless-stopped
    dns:
      - {{ ip_bind9 }}
    volumes:
      - {{ target_base }}/stepca/data:/home/step
    command: /usr/local/bin/step-ca /home/step/config/ca.json
    networks:
      core_net:
        ipv4_address: "{{ ip_stepca }}"
        aliases:
          - "{{ url_stepca }}"
    healthcheck:
      test: ["CMD", "curl", "-k", "-f", "https://localhost:9000/health"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s

  certbot:
    image: certbot/dns-rfc2136:latest
    container_name: certbot
    user: root
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    depends_on:
      bind9:
        condition: service_healthy
    extra_hosts:
      - "{{ url_stepca }}:{{ ip_stepca }}"
    environment:
      - REQUESTS_CA_BUNDLE=/etc/letsencrypt/root_ca.crt
    volumes:
      - {{ target_base }}/certbot/etc/letsencrypt:/etc/letsencrypt
      - /var/run/docker.sock:/var/run/docker.sock
      - {{ target_base }}/certbot/hooks:/etc/letsencrypt/renewal-hooks/deploy
    entrypoint: >
      /bin/sh -c "trap exit TERM; while :; do
      certbot renew;
      sleep 12h & wait $${!}; done;"
    networks:
      core_net:
    healthcheck:
      test: ["CMD", "pgrep", "-f", "certbot"]
      interval: 1m
      timeout: 5s
      retries: 2

networks:
  core_net:
    driver: bridge
    ipam:
      config:
        - subnet: "{{ core_subnet }}"
