services:
  nginx:
    image: {{ image_nginx }}
    container_name: nginx
    user: "{{ service_users.nginx.uid }}:{{ service_users.nginx.gid }}"
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,size=10m,uid={{ service_users.nginx.uid }},gid={{ service_users.nginx.gid }}
      - /var/cache/nginx:noexec,nosuid,size=50m,uid={{ service_users.nginx.uid }},gid={{ service_users.nginx.gid }}
      - /var/run:noexec,nosuid,size=5m,uid={{ service_users.nginx.uid }},gid={{ service_users.nginx.gid }}
      - /var/log/nginx:noexec,nosuid,size=5m,uid={{ service_users.nginx.uid }},gid={{ service_users.nginx.gid }}
      - /etc/nginx/conf.d:noexec,nosuid,size=1m,uid={{ service_users.nginx.uid }},gid={{ service_users.nginx.gid }}
    ports:
      - 80:80
      - "{{ host_ip }}:443:443"
      - "{{ host_ip }}:53:53/tcp"
      - "{{ host_ip }}:53:53/udp"
      - "{{ host_ip }}:853:853/tcp"
      - "{{ host_ip }}:389:389"
      - "{{ host_ip }}:636:636"
    volumes:
      - {{ deploy_base_dir }}/nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - {{ deploy_base_dir }}/nginx/certs:/etc/nginx/certs:ro
      - {{ deploy_base_dir }}/nginx/www:/srv/www:ro
    networks:
      core_net:
        ipv4_address: "{{ ip_nginx }}"
        aliases:
          - "{{ hostname_nginx }}"
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:80/"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

  bind9:
    image: {{ image_bind9 }}
    container_name: bind9
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
      - SETUID
      - SETGID
      - CHOWN
    ports:
      - "{{ bind_dns_port }}:53/tcp"
      - "{{ bind_dns_port }}:53/udp"
    volumes:
      - {{ deploy_base_dir }}/bind9/config:/etc/bind:ro
      - {{ deploy_base_dir }}/bind9/data:/var/lib/bind
      - {{ deploy_base_dir }}/bind9/log:/var/log
      - {{ deploy_base_dir }}/bind9/cache:/var/cache/bind
      - {{ deploy_base_dir }}/bind9/ssl:/etc/bind9/ssl:ro
    # Remap the container's bind user to our UID:GID, then hand off
    # to the stock entrypoint which runs: named -u bind -g
    entrypoint: ["/bin/sh", "-c"]
    command:
      - |
        groupmod -g {{ service_users.bind.gid }} bind
        usermod  -u {{ service_users.bind.uid }} -g {{ service_users.bind.gid }} -d /nonexistent bind
        chown {{ service_users.bind.uid }}:{{ service_users.bind.gid }} /run/named /var/cache/bind
        exec docker-entrypoint.sh -c /etc/bind/named.conf
    networks:
      core_net:
        ipv4_address: "{{ ip_bind9 }}"
        aliases:
          - "{{ hostname_bind9 }}"
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "su -s /bin/sh bind -c 'rndc status'"]
      interval: 10s
      start_period: 10s
      timeout: 5s
      retries: 3

  step-ca:
    image: {{ image_stepca }}
    container_name: step-ca
    user: "{{ service_users.step.uid }}:{{ service_users.step.gid }}"
    restart: unless-stopped
    dns:
      - {{ ip_bind9 }}
    volumes:
      - {{ deploy_base_dir }}/stepca/data:/home/step
    command:
      - /usr/local/bin/step-ca
      - /home/step/config/ca.json
{% if not byoc | default(false) | bool %}
      - --password-file
      - /home/step/secrets/password
{% endif %}
    networks:
      core_net:
        ipv4_address: "{{ ip_stepca }}"
        aliases:
          - "{{ hostname_stepca }}"
    healthcheck:
      test: ["CMD", "/usr/local/bin/step", "ca", "health", "--ca-url", "https://{{ hostname_stepca }}:{{ stepca_port }}", "--root", "/home/step/certs/root_ca.crt"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s

{% if install_ldap | default(false) | bool %}
  openldap:
    image: {{ image_openldap }}
    container_name: openldap
    environment:
      LDAP_ORGANISATION: "{{ cert_org }}"
      LDAP_DOMAIN: "{{ domain }}"
      LDAP_BASE_DN: "{{ ldap_base_dn }}"
      LDAP_ADMIN_PASSWORD: "{{ ldap_admin_password }}"
      LDAP_TLS: "true"
      LDAP_TLS_CRT_FILENAME: fullchain.pem
      LDAP_TLS_KEY_FILENAME: privkey.pem
      LDAP_TLS_CA_CRT_FILENAME: root_ca.crt
      LDAP_TLS_ENFORCE: "true"
      LDAP_TLS_VERIFY_CLIENT: "try"
    volumes:
      - {{ deploy_base_dir }}/openldap/data:/var/lib/ldap
      - {{ deploy_base_dir }}/openldap/config:/etc/ldap/slapd.d
      - {{ deploy_base_dir }}/openldap/certs:/container/service/slapd/assets/certs:ro
      - {{ deploy_base_dir }}/openldap/ous.ldif:/container/environment/custom/02-ous.ldif
      - {{ deploy_base_dir }}/openldap/groups.ldif:/container/environment/custom/03-groups.ldif
      - {{ deploy_base_dir }}/openldap/admins.ldif:/container/environment/custom/05-admins.ldif
      - {{ deploy_base_dir }}/openldap/acl.ldif:/container/environment/custom/06-acl.ldif
    networks:
      core_net:
        ipv4_address: "{{ ip_ldap }}"
        aliases:
          - "{{ hostname_ldap }}"
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "ldapsearch -x -b \"\" -s base -H ldap://localhost > /dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
{% endif %}

{% if install_keycloak | default(false) | bool %}
  postgres:
    image: {{ image_postgres }}
    container_name: postgres
    user: "{{ service_users.postgres.uid }}:{{ service_users.postgres.gid }}"
    command:
      - postgres
      - -c
      - ssl=on
      - -c
      - ssl_cert_file=/etc/postgres/certs/fullchain.pem
      - -c
      - ssl_key_file=/etc/postgres/certs/privkey.pem
    environment:
      POSTGRES_DB: keycloak
      POSTGRES_USER: keycloak
      POSTGRES_PASSWORD: "{{ keycloak_db_password }}"
    volumes:
      - {{ deploy_base_dir }}/postgres/data:/var/lib/postgresql/data
      - {{ deploy_base_dir }}/postgres/certs:/etc/postgres/certs:ro
    networks:
      core_net:
        ipv4_address: "{{ ip_postgres }}"
        aliases:
          - postgres
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U keycloak -d keycloak"]
      interval: 10s
      timeout: 5s
      retries: 5

  keycloak:
    image: {{ image_keycloak }}
    container_name: keycloak
    user: "{{ service_users.keycloak.uid }}:{{ service_users.keycloak.gid }}"
    command: start-dev
    environment:
      KC_DB: postgres
      KC_DB_URL: jdbc:postgresql://postgres:5432/keycloak?sslmode=verify-full&sslrootcert=/etc/keycloak/certs/root_ca.crt
      KC_DB_USERNAME: keycloak
      KC_DB_PASSWORD: "{{ keycloak_db_password }}"
      KC_HOSTNAME: "{{ hostname_keycloak }}"
      KC_PROXY_HEADERS: xforwarded
      KC_HTTP_ENABLED: "true"
      KC_HTTPS_CERTIFICATE_FILE: /etc/keycloak/certs/fullchain.pem
      KC_HTTPS_CERTIFICATE_KEY_FILE: /etc/keycloak/certs/privkey.pem
      KC_TRUSTSTORE_PATHS: /etc/keycloak/certs/root_ca.crt
      KEYCLOAK_ADMIN: "{{ keycloak_admin_user }}"
      KEYCLOAK_ADMIN_PASSWORD: "{{ keycloak_admin_password }}"
    volumes:
      - {{ deploy_base_dir }}/keycloak/data:/opt/keycloak/data
      - {{ deploy_base_dir }}/keycloak/certs:/etc/keycloak/certs:ro
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      core_net:
        ipv4_address: "{{ ip_keycloak }}"
        aliases:
          - "{{ hostname_keycloak }}"
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "curl -k -s -f https://localhost:8443/health/ready || (exec 3<>/dev/tcp/127.0.0.1/8080 && echo -e 'GET /health/ready HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n' >&3 && cat <&3 | grep -q '200 OK')"]
      interval: 30s
      timeout: 5s
      retries: 3
{% endif %}

networks:
  core_net:
    name: core_net
    external: true
