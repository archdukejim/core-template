<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ friendly_name | default(ca_name) }} &mdash; PKI Certificates</title>
  <script>
    try {
        const savedTheme = localStorage.getItem('selected-theme');
        if (savedTheme && savedTheme !== 'auto') {
            document.documentElement.setAttribute('data-theme', savedTheme);
        }
    } catch (e) {}
  </script>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <div class="container">
    <header>
      <div class="header-content">
        <h1>{{ friendly_name | default(ca_name) }}</h1>
        <p class="subtitle">{{ cert_org }} &mdash; Internal PKI Certificate Authority</p>
      </div>
      <div class="theme-selector">
        <select id="theme-select" class="theme-select" aria-label="Select Theme">
          <option value="auto">System Auto</option>
          <option value="light">Light</option>
          <option value="dark">Dark</option>
          <option value="army">Army</option>
          <option value="navy">Navy</option>
          <option value="air-force">Air Force</option>
          <option value="marines">Marines</option>
          <option value="coast-guard">Coast Guard</option>
          <option value="space-force">Space Force</option>
          <option value="cyberpunk">Cyberpunk</option>
        </select>
      </div>
    </header>

    <!-- Top Tabs -->
    <div class="tabs-wrapper">
      <div class="tabs">
        <button class="tab active" onclick="showTab(event,'tab-ubuntu')">Ubuntu (Easy)</button>
        <button class="tab" onclick="showTab(event,'tab-browsers')">Browsers (Easy)</button>
        <button class="tab" onclick="showTab(event,'tab-linux-manual')">Linux (Manual)</button>
        <button class="tab" onclick="showTab(event,'tab-browsers-manual')">Browsers (Manual)</button>
        <button class="tab" onclick="showTab(event,'tab-windows')">Windows</button>
        <button class="tab" onclick="showTab(event,'tab-chain')">Certificate Chain</button>
      </div>
    </div>

    <!-- Tab Contents -->
    <div class="tab-content active" id="tab-ubuntu">
      <div class="card">
        <h2>Ubuntu Auto Installation</h2>
        <p style="color:var(--muted);font-size:.9rem;margin-bottom:1rem;">
          Run these scripts to automatically configure your system to trust the internal CA.
        </p>
        
        <strong>1. All-in-One Installer (Recommended):</strong>
        <p style="color:var(--muted);font-size:.85rem;margin-top:.5rem;">Installs OS certificates, configures Python, Firefox, and Chrome/Chromium automatically.</p>
        <pre><code><span class="cmd">wget</span> -qO- https://{{ hostname_certs }}/install-all-{{ domain_file }}.sh | <span class="cmd">sudo bash</span></code></pre>
        
        <strong style="display:block;margin-top:1.5rem;">2. System Certificates Only (OS Level):</strong>
        <pre><code><span class="cmd">wget</span> -qO- https://{{ hostname_certs }}/install-certs-{{ domain_file }}.sh | <span class="cmd">sudo bash</span></code></pre>
        
        <strong style="display:block;margin-top:1.5rem;">3. Python Applications Only:</strong>
        <p style="color:var(--muted);font-size:.85rem;margin-top:.5rem;">Updates the global Requests library and environment variables.</p>
        <pre><code><span class="cmd">wget</span> -qO- https://{{ hostname_certs }}/install-python-{{ domain_file }}.sh | <span class="cmd">sudo bash</span></code></pre>
      </div>
    </div>

    <div class="tab-content" id="tab-browsers">
      <div class="card">
        <h2>Web Browsers (Ubuntu)</h2>
        <p style="color:var(--muted);font-size:.9rem;margin-bottom:1rem;">
          Browsers on Linux use their own NSS databases. These scripts inject the already-installed Root CA from your system into your browsers. <em>(Make sure you've run the OS installer first!)</em>
        </p>
        
        <strong>Firefox (Standard / Debian ESR / Snap):</strong>
        <pre><code><span class="cmd">wget</span> -qO- https://{{ hostname_certs }}/install-firefox-{{ domain_file }}.sh | <span class="cmd">sudo bash</span></code></pre>

        <strong style="display:block;margin-top:1.5rem;">Chrome, Chromium, Brave, Edge (Standard / Snap):</strong>
        <pre><code><span class="cmd">wget</span> -qO- https://{{ hostname_certs }}/install-chrome-{{ domain_file }}.sh | <span class="cmd">sudo bash</span></code></pre>
      </div>
    </div>

    <div class="tab-content" id="tab-linux-manual">
      <div class="card">
        <h2>Manual Linux Installation</h2>
        <p style="color:var(--muted);font-size:.9rem;margin-bottom:1rem;">
          If you prefer to install the certificates manually or are on a different distribution.
        </p>

        <div class="downloads">
          <a class="btn btn-primary" href="{{ root_cert_name }}.crt" download>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
            Root CA
          </a>
          <a class="btn btn-secondary" href="{{ domain_file }}_ca.crt" download>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
            Intermediate CA
          </a>
        </div>

        <strong>Debian / Ubuntu:</strong>
        <pre><code><span class="cmd">wget</span> -q --no-check-certificate https://{{ hostname_certs }}/{{ root_cert_name }}.crt -O /tmp/{{ domain_file }}-root.crt
<span class="cmd">sudo cp</span> /tmp/{{ domain_file }}-root.crt /usr/local/share/ca-certificates/root.crt
<span class="cmd">sudo update-ca-certificates --fresh</span></code></pre>
        <strong style="display:block;margin-top:1rem;">RHEL / Fedora:</strong>
        <pre><code><span class="cmd">curl</span> -kso /tmp/{{ domain_file }}-root.crt https://{{ hostname_certs }}/{{ root_cert_name }}.crt
<span class="cmd">sudo cp</span> /tmp/{{ domain_file }}-root.crt /etc/pki/ca-trust/source/anchors/root.crt
<span class="cmd">sudo update-ca-trust</span></code></pre>
        <strong style="display:block;margin-top:1rem;">Python Requests (Manual Setup):</strong>
        <pre><code><span class="cmd">export</span> REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
<span class="cmd">export</span> SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt</code></pre>
      </div>
    </div>

    <div class="tab-content" id="tab-browsers-manual">
      <div class="card">
        <h2>Manual Browser Installation</h2>
        <p style="color:var(--muted);font-size:.9rem;margin-bottom:1rem;">
          To manually install the certificate into Chrome/Firefox NSS databases.
        </p>

        <strong>Using certutil (libnss3-tools):</strong>
        <pre><code><span class="cmd">wget</span> -q --no-check-certificate https://{{ hostname_certs }}/{{ root_cert_name }}.crt -O /tmp/{{ root_cert_name }}.crt
<span class="cmd">certutil</span> -d sql:$HOME/.pki/nssdb -A -t "C,," -n "{{ friendly_name }} Root CA" -i /tmp/{{ root_cert_name }}.crt</code></pre>
        <strong style="display:block;margin-top:1rem;">Firefox Settings Menu:</strong>
        <p style="color:var(--muted);font-size:.85rem;margin-top:.5rem;">
          1. Go to <strong>Settings</strong> &rarr; <strong>Privacy &amp; Security</strong><br>
          2. Scroll down to <strong>Certificates</strong> and click <strong>View Certificates...</strong><br>
          3. Go to the <strong>Authorities</strong> tab.<br>
          4. Click <strong>Import...</strong> and select the downloaded <code>{{ root_cert_name }}.crt</code> file.<br>
          5. Check "Trust this CA to identify websites" and click OK.
        </p>
      </div>
    </div>

    <div class="tab-content" id="tab-windows">
      <div class="card">
        <h2>Windows Installation</h2>
        <p style="color:var(--muted);font-size:.9rem;margin-bottom:1rem;">
          Install the certificates into the Windows Local Machine certificate store.
        </p>
        <strong>Via PowerShell (Administrator):</strong>
        <pre><code><span class="cmd">Invoke-WebRequest</span> -Uri https://{{ hostname_certs }}/{{ root_cert_name }}_win.cer `
  -OutFile $env:TEMP\{{ root_cert_name }}_win.cer -SkipCertificateCheck
<span class="cmd">Invoke-WebRequest</span> -Uri https://{{ hostname_certs }}/{{ domain_file }}_win_ca.cer `
  -OutFile $env:TEMP\{{ domain_file }}_win_ca.cer -SkipCertificateCheck
<span class="cmd">Import-Certificate</span> -FilePath $env:TEMP\{{ root_cert_name }}_win.cer `
  -CertStoreLocation Cert:\LocalMachine\Root
<span class="cmd">Import-Certificate</span> -FilePath $env:TEMP\{{ domain_file }}_win_ca.cer `
  -CertStoreLocation Cert:\LocalMachine\CA</code></pre>
        <p style="color:var(--muted);font-size:.85rem;margin-top:.75rem;">
          Or download the files using the buttons below and double-click each file &rarr; <em>Install Certificate</em> &rarr; <em>Local Machine</em> &rarr; select the appropriate store (Root CA &rarr; <em>Trusted Root Certification Authorities</em>).
        </p>
        <div class="downloads" style="margin-top:1rem;">
          <a class="btn btn-primary" href="{{ root_cert_name }}_win.cer" download>Root CA</a>
          <a class="btn btn-secondary" href="{{ domain_file }}_win_ca.cer" download>Intermediate CA</a>
        </div>
      </div>
    </div>

    <div class="tab-content" id="tab-chain">
      <!-- Trust chain -->
      <div class="chain">
        <div class="chain-node">
          <span class="chain-label label-root">Root CA</span>
          <div class="chain-cn">{{ cert_org }} Root CA</div>
          <div class="chain-meta">Self-signed &bull; {{ cert_root_key_type | upper }} {{ cert_root_key_param }} &bull; {{ cert_root_ca_days // 365 }}-year validity</div>
        </div>
        <div class="chain-connector"></div>
        <div class="chain-node">
          <span class="chain-label label-intermediate">Intermediate CA</span>
          <div class="chain-cn">Intermediate CA</div>
          <div class="chain-meta">Signed by Root &bull; {{ cert_intermediate_key_type | upper }} {{ cert_intermediate_key_param }} &bull; {{ cert_intermediate_days // 365 }}-year validity</div>
        </div>
        <div class="chain-connector"></div>
        <div class="chain-node">
          <span class="chain-label label-leaf">Leaf Certificates</span>
          <div class="chain-cn">*.{{ domain }}</div>
          <div class="chain-meta">Issued via ACME or offline mint &bull; {{ cert_acme_lifetime_hours | replace('h','') | int // 24 }}-day default</div>
        </div>
      </div>

      <!-- Subject info -->
      <div class="card" style="margin-top:2.5rem;">
        <h2>Certificate Subject Details</h2>
        <table class="subject-table">
          <tr><th>Country (C)</th><td>{{ cert_country }}</td></tr>
          <tr><th>State (ST)</th><td>{{ cert_province }}</td></tr>
          <tr><th>Locality (L)</th><td>{{ cert_city }}</td></tr>
          <tr><th>Organization (O)</th><td>{{ cert_org }}</td></tr>
          <tr><th>Org Unit (OU)</th><td>{{ cert_ou }}</td></tr>
        </table>
      </div>
    </div>

    <footer>
      {{ ca_name }} &bull; {{ hostname_stepca }} &bull; Served by Step-CA + Nginx
    </footer>
  </div>

  <script>
    function showTab(e, id) {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      e.target.classList.add('active');
      document.getElementById(id).classList.add('active');
    }

    const themeSelect = document.getElementById('theme-select');
    let currentTheme = 'auto';
    try {
        currentTheme = localStorage.getItem('selected-theme') || 'auto';
    } catch (e) {}
    
    themeSelect.value = currentTheme;

    themeSelect.addEventListener('change', (e) => {
        const theme = e.target.value;
        if (theme === 'auto') {
            document.documentElement.removeAttribute('data-theme');
        } else {
            document.documentElement.setAttribute('data-theme', theme);
        }
        try {
            localStorage.setItem('selected-theme', theme);
        } catch (e) {}
    });
  </script>
</body>
</html>
