#!/usr/bin/env bash
set -euo pipefail

BASE_URL="https://{{ hostname_certs }}"
DOMAIN="{{ domain_file }}"

echo "================================================="
echo " Starting All-in-One CA Installation "
echo "================================================="
echo ""

echo ">>> 1. Installing OS Certificates..."
if wget -qO- "$BASE_URL/install-certs-$DOMAIN.sh" | bash; then
    echo "[OK] OS Certificates installed."
else
    echo "[ERROR] Failed to install OS certificates. Aborting."
    exit 1
fi
echo ""

echo ">>> 2. Configuring Python Applications..."
if command -v python3 >/dev/null 2>&1; then
    if wget -qO- "$BASE_URL/install-python-$DOMAIN.sh" | bash; then
        echo "[OK] Python configured."
    else
        echo "[WARNING] Failed to configure Python."
    fi
else
    echo "[SKIP] Python 3 not found on this system."
fi
echo ""

echo ">>> 3. Configuring Firefox..."
if command -v firefox >/dev/null 2>&1 || [ -d "$HOME/.mozilla/firefox" ] || [ -d "/snap/firefox" ] || [ -d "/etc/firefox" ]; then
    if wget -qO- "$BASE_URL/install-firefox-$DOMAIN.sh" | bash; then
        echo "[OK] Firefox configured."
    else
        echo "[WARNING] Firefox configuration failed."
    fi
else
    echo "[SKIP] Firefox not found on this system."
fi
echo ""

echo ">>> 4. Configuring Chrome/Chromium/Brave/Edge..."
if command -v google-chrome >/dev/null 2>&1 || command -v chromium >/dev/null 2>&1 || command -v chromium-browser >/dev/null 2>&1 || command -v brave >/dev/null 2>&1 || command -v microsoft-edge >/dev/null 2>&1 || [ -d "$HOME/.pki/nssdb" ] || [ -d "/snap/chromium" ]; then
    if wget -qO- "$BASE_URL/install-chrome-$DOMAIN.sh" | bash; then
        echo "[OK] Chrome/Chromium configured."
    else
        echo "[WARNING] Chrome/Chromium configuration failed."
    fi
else
    echo "[SKIP] Chrome-based browsers not found on this system."
fi
echo ""

echo "================================================="
echo " All-in-One Installation Complete! "
echo "================================================="
