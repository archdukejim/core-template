<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ friendly_name | default(ca_name) }} &mdash; Core Infrastructure Landing</title>
  <script>
    try {
        const savedTheme = localStorage.getItem('selected-theme');
        if (savedTheme && savedTheme !== 'auto') {
            document.documentElement.setAttribute('data-theme', savedTheme);
        }
    } catch (e) {}
  </script>
  <link rel="stylesheet" href="/style.css">
  <style>
    .link-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .link-list li {
        margin-bottom: 0.75rem;
    }
    .link-list .btn {
        display: flex;
        width: 100%;
    }
    .link-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 0.75rem;
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .link-grid li {
        display: flex;
    }
    .link-grid .btn {
        width: 100%;
        height: 100%;
        text-align: center;
        padding: 0.75rem 1rem;
    }
    .section-title {
        margin-top: 2rem;
        margin-bottom: 1rem;
        font-size: 1.2rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 0.5rem;
        color: var(--heading);
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <div class="header-content">
        <h1>{{ friendly_name | default(ca_name) }}</h1>
        <p class="subtitle">Core Infrastructure Landing Portal</p>
      </div>
      <div class="theme-selector">
        <select id="theme-select" class="theme-select" aria-label="Select Theme">
          <option value="auto">System Auto</option>
          <option value="light">Light</option>
          <option value="dark">Dark</option>
          <option value="army">Army</option>
          <option value="navy">Navy</option>
          <option value="air-force">Air Force</option>
          <option value="marines">Marines</option>
          <option value="coast-guard">Coast Guard</option>
          <option value="space-force">Space Force</option>
          <option value="cyberpunk">Cyberpunk</option>
        </select>
      </div>
    </header>

    <div class="card" style="margin-top: 2rem;">
      <h2 class="section-title" style="margin-top: 0;">Documentation & Setup</h2>
      <ul class="link-list">
        <li><a href="/manual/" class="btn">Infrastructure Manual (Documentation)</a></li>
        <li><a href="/certificates/" class="btn">PKI Certificates & Auto-Installers</a></li>
        <li><a href="/ldap/" class="btn">LDAP Authentication & Client Setup</a></li>
      </ul>

      {% if links is defined and links | length > 0 %}
      <h2 class="section-title">Links</h2>
      <ul class="link-grid">
        {% for item in links %}
        <li><a href="https://{{ item.link }}" class="btn">{{ item.name }}</a></li>
        {% endfor %}
      </ul>
      {% endif %}


    </div>

    <footer>
      &#10227; Last Updated: {{ ansible_date_time.date | default('2026-04-29') }}.<br>
      {% if copyright | default('') %}&#169; {{ copyright }} {% endif %}{{ friendly_name | default(ca_name) }}{% if service_mark | default('') %} &#8480; {{ service_mark }}{% endif %}{% if trademark | default('') %} &#8482; {{ trademark }}{% endif %}
      {% if address_line1 | default('') or address_line2 | default('') %}
      <br>{{ address_line1 | default('') }}{% if address_line1 | default('') and address_line2 | default('') %}, {% endif %}{{ address_line2 | default('') }}
      {% endif %}
      {% if contact_phone | default('') or contact_email | default('') %}
      <br>{% if contact_phone | default('') %}{{ contact_phone }}{% endif %}{% if contact_phone | default('') and contact_email | default('') %} | {% endif %}{% if contact_email | default('') %}{{ contact_email }}{% endif %}
      {% endif %}
      {% if care_of | default('') %}
      <br>&#8453; {{ care_of }}
      {% endif %}
    </footer>
  </div>

  <script>
    const themeSelect = document.getElementById('theme-select');
    let currentTheme = 'auto';
    try {
        currentTheme = localStorage.getItem('selected-theme') || 'auto';
    } catch (e) {}
    
    themeSelect.value = currentTheme;

    themeSelect.addEventListener('change', (e) => {
        const theme = e.target.value;
        if (theme === 'auto') {
            document.documentElement.removeAttribute('data-theme');
        } else {
            document.documentElement.setAttribute('data-theme', theme);
        }
        try {
            localStorage.setItem('selected-theme', theme);
        } catch (e) {}
    });
  </script>
</body>
</html>
