{# nginx.conf — rendered by Ansible from nginx/nginx.conf.j2         #}
{# ----------------------------------------------------------------- #}

# Global settings
worker_processes  auto;
worker_rlimit_nofile 65535;
error_log  /var/log/nginx/error.log notice;
pid        /tmp/nginx.pid;

events {
    multi_accept on;
    worker_connections  16384;
}

# DNS / LDAP stream proxies
stream {
    resolver 127.0.0.11 valid=30s;

    # DNS - UDP (nginx proxies port 53 → BIND9)
    server {
        listen 53 udp reuseport;
        proxy_pass bind9:53;
        proxy_responses 1;
        proxy_timeout 1s;
        proxy_buffer_size 16k;
    }

    # DNS - TCP
    server {
        listen 53;
        proxy_pass bind9:53;
        proxy_timeout 3s;
    }

    # DNS over TLS — nginx terminates TLS, forwards plain DNS to BIND9
    server {
        listen 853 ssl;
        proxy_pass bind9:53;
        ssl_certificate     /etc/nginx/certs/{{ hostname_bind9 }}/fullchain.pem;
        ssl_certificate_key /etc/nginx/certs/{{ hostname_bind9 }}/privkey.pem;
        ssl_protocols       TLSv1.2 TLSv1.3;
        proxy_timeout 10s;
    }

    # LDAP - plain TCP
    server {
        listen 389;
        set $ldap_backend "{{ nginx_backend_ldap }}";
        proxy_pass $ldap_backend;
        proxy_timeout 10s;
        proxy_connect_timeout 5s;
    }

    # LDAPS — nginx terminates TLS, forwards plain LDAP to backend
    server {
        listen 636 ssl;
        set $ldaps_backend "{{ nginx_backend_ldap }}";
        proxy_pass $ldaps_backend;
        ssl_certificate     /etc/nginx/certs/{{ hostname_ldap }}/fullchain.pem;
        ssl_certificate_key /etc/nginx/certs/{{ hostname_ldap }}/privkey.pem;
        ssl_protocols       TLSv1.2 TLSv1.3;
        proxy_timeout 10s;
        proxy_connect_timeout 5s;
    }
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    # Non-root user (UID {{ service_users.nginx.uid }}) temp paths
    client_body_temp_path /tmp/client_temp;
    proxy_temp_path       /tmp/proxy_temp;
    fastcgi_temp_path     /tmp/fastcgi_temp;
    uwsgi_temp_path       /tmp/uwsgi_temp;
    scgi_temp_path        /tmp/scgi_temp;

    resolver 127.0.0.11 valid=30s;

    # HTTP — health check, ACME passthrough, redirect everything else to HTTPS
    server {
        listen 80 default_server;
        server_name _;

        location /health {
            access_log off;
            return 200 'OK';
        }

        location / {
            return 301 https://$host$request_uri;
        }
    }

    # HTTPS — DNS-over-HTTPS via BIND9
    # nginx terminates TLS; BIND9 serves plain HTTP DoH on port {{ bind9_doh_port }}.
    server {
        listen 443 ssl;
        server_name {{ hostname_bind9 }};

        ssl_certificate     /etc/nginx/certs/{{ hostname_bind9 }}/fullchain.pem;
        ssl_certificate_key /etc/nginx/certs/{{ hostname_bind9 }}/privkey.pem;
        ssl_protocols       TLSv1.2 TLSv1.3;

        location /dns-query {
            proxy_pass http://bind9:{{ bind9_doh_port }};
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_http_version 1.1;
        }
    }

    # Step-CA — pass HTTPS through to Step-CA's native TLS on port {{ stepca_port }}
    server {
        listen 443 ssl;
        server_name {{ hostname_stepca }};

        ssl_certificate     /etc/nginx/certs/{{ hostname_stepca }}/fullchain.pem;
        ssl_certificate_key /etc/nginx/certs/{{ hostname_stepca }}/privkey.pem;
        ssl_protocols       TLSv1.2 TLSv1.3;

        set $stepca_backend "{{ nginx_backend_stepca }}";

        # PKI info page and certificate downloads
        location = /certificates {
            return 301 /certificates/;
        }
        location = /certificates/ {
            alias /srv/www/certificates/;
            index index.html;
        }
        location = /certificates/index.html {
            alias /srv/www/certificates/index.html;
        }
        location = /certificates/root_ca.crt {
            alias /srv/www/certificates/root_ca.crt;
            default_type application/x-pem-file;
            add_header Content-Disposition 'attachment; filename="root_ca.crt"';
        }
        location = /certificates/intermediate_ca.crt {
            alias /srv/www/certificates/intermediate_ca.crt;
            default_type application/x-pem-file;
            add_header Content-Disposition 'attachment; filename="intermediate_ca.crt"';
        }
        location = /certificates/install-certs-{{ domain }}.sh {
            alias /srv/www/certificates/install-certs-{{ domain }}.sh;
            default_type text/x-shellscript;
            add_header Content-Disposition 'attachment; filename="install-certs-{{ domain }}.sh"';
        }
        location = /certificates/install-firefox-{{ domain }}.sh {
            alias /srv/www/certificates/install-firefox-{{ domain }}.sh;
            default_type text/x-shellscript;
            add_header Content-Disposition 'attachment; filename="install-firefox-{{ domain }}.sh"';
        }
        location = /certificates/install-chrome-{{ domain }}.sh {
            alias /srv/www/certificates/install-chrome-{{ domain }}.sh;
            default_type text/x-shellscript;
            add_header Content-Disposition 'attachment; filename="install-chrome-{{ domain }}.sh"';
        }
        location = /certificates/install-all-{{ domain }}.sh {
            alias /srv/www/certificates/install-all-{{ domain }}.sh;
            default_type text/x-shellscript;
            add_header Content-Disposition 'attachment; filename="install-all-{{ domain }}.sh"';
        }
        location = /certificates/install-python-{{ domain }}.sh {
            alias /srv/www/certificates/install-python-{{ domain }}.sh;
            default_type text/x-shellscript;
            add_header Content-Disposition 'attachment; filename="install-python-{{ domain }}.sh"';
        }

        location / {
            proxy_pass $stepca_backend;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_ssl_verify off;
        }
    }

    # PKI certificate download page
    server {
        listen 443 ssl;
        server_name {{ hostname_certs }};

        ssl_certificate     /etc/nginx/certs/{{ hostname_certs }}/fullchain.pem;
        ssl_certificate_key /etc/nginx/certs/{{ hostname_certs }}/privkey.pem;
        ssl_protocols       TLSv1.2 TLSv1.3;

        location / {
            root /srv/www/certificates;
            index index.html;
            default_type text/html;
        }
        location = /root_ca.crt {
            alias /srv/www/certificates/root_ca.crt;
            default_type application/x-pem-file;
            add_header Content-Disposition 'attachment; filename="root_ca.crt"';
        }
        location = /intermediate_ca.crt {
            alias /srv/www/certificates/intermediate_ca.crt;
            default_type application/x-pem-file;
            add_header Content-Disposition 'attachment; filename="intermediate_ca.crt"';
        }
        location = /install-certs-{{ domain }}.sh {
            alias /srv/www/certificates/install-certs-{{ domain }}.sh;
            default_type text/x-shellscript;
            add_header Content-Disposition 'attachment; filename="install-certs-{{ domain }}.sh"';
        }
        location = /install-firefox-{{ domain }}.sh {
            alias /srv/www/certificates/install-firefox-{{ domain }}.sh;
            default_type text/x-shellscript;
            add_header Content-Disposition 'attachment; filename="install-firefox-{{ domain }}.sh"';
        }
        location = /install-chrome-{{ domain }}.sh {
            alias /srv/www/certificates/install-chrome-{{ domain }}.sh;
            default_type text/x-shellscript;
            add_header Content-Disposition 'attachment; filename="install-chrome-{{ domain }}.sh"';
        }
        location = /install-all-{{ domain }}.sh {
            alias /srv/www/certificates/install-all-{{ domain }}.sh;
            default_type text/x-shellscript;
            add_header Content-Disposition 'attachment; filename="install-all-{{ domain }}.sh"';
        }
        location = /install-python-{{ domain }}.sh {
            alias /srv/www/certificates/install-python-{{ domain }}.sh;
            default_type text/x-shellscript;
            add_header Content-Disposition 'attachment; filename="install-python-{{ domain }}.sh"';
        }
    }

{% if install_keycloak | default(false) | bool %}
    # Keycloak Web UI / API
    server {
        listen 443 ssl;
        server_name {{ hostname_keycloak }};

        ssl_certificate /etc/nginx/certs/{{ hostname_keycloak }}/fullchain.pem;
        ssl_certificate_key /etc/nginx/certs/{{ hostname_keycloak }}/privkey.pem;

        location / {
            set $keycloak_backend "https://keycloak:8443";
            proxy_pass $keycloak_backend;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Host $host;
            proxy_set_header X-Forwarded-Port 443;
            proxy_ssl_verify off;
        }
    }
{% endif %}
}
