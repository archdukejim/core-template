{% set tsig_primary = tsig_keys | selectattr('primary', 'defined') | selectattr('primary', 'equalto', true) | first %}
{% for zone_name, zone_records in dns.items() %}
zone "{{ zone_name }}" {
    type master;
    file "/var/lib/bind/db.{{ zone_name }}";
    allow-query { {% for acl_name in bind_acls.keys() %}"{{ acl_name }}"; {% endfor %}};
    allow-transfer { none; };
    update-policy {
        // --- acme-dns-01 ---
        // The primary ACME key may update any _acme-challenge TXT record in this zone.
{% if tsig_primary.domain == zone_name %}
        grant "{{ tsig_primary.name }}" subdomain _acme-challenge TXT;
{% endif %}

        // --- additional keys ---
        // Keys added by add-tsig-key.sh will appear below this line.
        // (managed outside of Ansible — do not remove this comment)
    };
};

{% endfor %}
