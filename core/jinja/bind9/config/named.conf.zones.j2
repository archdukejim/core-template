{% for zone_key, zone_records in dns.items() %}
{% set zone_name = domain if zone_key == 'dynamic_zone_var' else zone_key %}
zone "{{ zone_name }}" {
    type master;
    file "/var/lib/bind/db.{{ zone_name }}";
    allow-query { {% for acl_name in bind_acls.keys() %}"{{ acl_name }}"; {% endfor %}};
    allow-transfer { none; };
    update-policy {
{% for key in tsig_keys %}
{% if key.record_types is defined and key.domain == zone_name %}
{% if key.primary is defined and key.primary %}
        // {{ key.name }} — ACME challenge updates
        grant "{{ key.name }}" subdomain _acme-challenge {{ key.record_types | join(' ') }};
{% else %}
        // {{ key.name }} — zone record updates
        grant "{{ key.name }}" zonesub {{ key.record_types | join(' ') }};
{% endif %}
{% endif %}
{% endfor %}

        // --- additional keys ---
        // Keys added by add-tsig-key.sh will appear below this line.
        // (managed outside of Ansible — do not remove this comment)
    };
};

{% endfor %}
