options {
    directory "/var/cache/bind";

    // Listener configuration
    listen-on port 53 { any; };                   // used by step-ca and container system resolvers; host maps {{ bind_dns_port }}:53
    listen-on port {{ bind9_doh_port }} tls none http dns-over-https { any; };  // DoH — nginx terminates TLS, plain HTTP inbound
    listen-on-v6 { any; };

    // Authoritative only — no recursive resolution
    recursion no;

    // DNSSEC — validation disabled; this is an internal authoritative-only
    // server serving private zones with no path to root servers.
    // dnssec-validation auto would trigger a priming query that times out
    // on isolated networks, blocking startup and query responses.
    dnssec-validation no;

    // Hardening
    allow-query { any; };
    allow-transfer { none; };
    minimal-responses yes;

    rate-limit {
        responses-per-second 10;
        slip 2;
        window 10;
    };
};
