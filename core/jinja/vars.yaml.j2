---
# ============================================================
# RESOLVED VARS — auto-generated by 01-render-jinja.yml
# Sources: /custom-vars.yaml  +  core/advanced-vars.yaml
#
# Do not edit directly — regenerated on every run of 01-render-jinja.yml.
# To change settings edit the source files above.
# ============================================================

# ============================================================
# GLOBAL
# ============================================================
domain: {{ domain }}
hostname: {{ hostname }}
system_timezone: {{ system_timezone }}
deploy_base_dir: {{ deploy_base_dir }}
repo_source: {{ repo_source }}

# ============================================================
# NETWORK
# ============================================================
lan_cidr: {{ lan_cidr }}
lan_gateway: {{ lan_gateway }}
dns_server: {{ dns_server }}
core_subnet: {{ core_subnet }}
pi_core_ip: {{ pi_core_ip }}

# ============================================================
# SERVICE IPs
# ============================================================
ip_nginx: {{ ip_nginx }}
ip_bind9: {{ ip_bind9 }}
ip_stepca: {{ ip_stepca }}
ip_ldap: {{ ip_ldap }}

# ============================================================
# SERVICE HOSTNAMES
# ============================================================
hostname_nginx: {{ hostname_nginx }}
hostname_bind9: {{ hostname_bind9 }}
hostname_stepca: {{ hostname_stepca }}
hostname_ldap: {{ hostname_ldap }}

# ============================================================
# DOCKER IMAGES
# ============================================================
image_nginx: {{ image_nginx }}
image_bind9: {{ image_bind9 }}
image_stepca: {{ image_stepca }}
image_alpine_tools: {{ image_alpine_tools }}

# ============================================================
# DOCKER / SERVICE INFRASTRUCTURE
# ============================================================
compose_file: {{ compose_file }}
project_containers:
{{ project_containers | to_nice_yaml(indent=2) | indent(2, first=True) }}
service_dirs:
{{ service_dirs | to_nice_yaml(indent=2) | indent(2, first=True) }}
service_users:
{{ service_users | to_nice_yaml(indent=2) | indent(2, first=True) }}

# ============================================================
# CERTIFICATES / PKI
# ============================================================
ca_name: {{ ca_name }}
cert_country: {{ cert_country }}
cert_province: {{ cert_province }}
cert_city: {{ cert_city }}
cert_org: {{ cert_org }}
cert_ou: {{ cert_ou }}
cert_root_ca_days: {{ cert_root_ca_days }}
cert_root_digest: {{ cert_root_digest }}
cert_root_key_type: {{ cert_root_key_type }}
cert_root_key_param: '{{ cert_root_key_param }}'
cert_intermediate_days: {{ cert_intermediate_days }}
cert_intermediate_digest: {{ cert_intermediate_digest }}
cert_intermediate_key_type: {{ cert_intermediate_key_type }}
cert_intermediate_key_param: '{{ cert_intermediate_key_param }}'
cert_service_days: {{ cert_service_days }}

# ============================================================
# STEP-CA
# ============================================================
stepca_port: {{ stepca_port }}
stepca_cert_allow_subordinate_ca: {{ stepca_cert_allow_subordinate_ca | lower }}
stepca_cert_max_lifetime_hours: {{ stepca_cert_max_lifetime_hours }}
cert_acme_lifetime_hours: {{ cert_acme_lifetime_hours }}

# ============================================================
# DNS — BIND9
# ============================================================
bind_dns_port: {{ bind_dns_port }}
bind9_doh_port: {{ bind9_doh_port }}
bind_acls:
{{ bind_acls | to_nice_yaml(indent=2) | indent(2, first=True) }}
dns:
{{ dns | to_nice_yaml(indent=2) | indent(2, first=True) }}
tsig_keys:
{{ tsig_keys | to_nice_yaml(indent=2) | indent(2, first=True) }}

# ============================================================
# NGINX BACKENDS
# ============================================================
nginx_backend_ldap: {{ nginx_backend_ldap }}
nginx_backend_stepca: {{ nginx_backend_stepca }}

# ============================================================
# LDAP / OPENLDAP — base DN computed from domain
# ============================================================
ldap_base_dn: {{ domain.split('.') | map('regex_replace', '^', 'dc=') | join(',') }}
ldap_domain_components:
{{ domain.split('.') | to_nice_yaml(indent=2) | indent(2, first=True) }}
ldap_groups:
{{ ldap_groups | to_nice_yaml(indent=2) | indent(2, first=True) }}
ldap_organizational_units:
{{ ldap_organizational_units | to_nice_yaml(indent=2) | indent(2, first=True) }}
