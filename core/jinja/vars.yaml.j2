---
# ============================================================
# RESOLVED VARS — auto-generated by 01-render-jinja.yml
# Sources: /custom-vars.yaml
#
# Do not edit directly — regenerated on every run of 01-render-jinja.yml.
# To change settings edit the source files above.
# ============================================================

# ============================================================
# GLOBAL
# ============================================================
domain: {{ domain }}
domain_file: {{ domain_file | default(domain | replace('.', '_')) }}
hostname: {{ hostname }}
friendly_name: {{ friendly_name | default("Example Org") }}
system_timezone: {{ system_timezone | default('America/New_York') }}
deploy_base_dir: {{ deploy_base_dir | default('/opt') }}
repo_source: {{ repo_source | default(playbook_dir | dirname | dirname) }}

# ============================================================
# NETWORK
# ============================================================
lan_cidr: {{ lan_cidr }}
lan_gateway: {{ lan_gateway }}
dns_server: {{ dns_server | default('8.8.8.8') }}
use_host_dns: {{ use_host_dns | default(true) | lower }}
core_subnet: {{ core_subnet | default('10.255.0.0/24') }}
host_ip: {{ host_ip }}

# ============================================================
# SERVICE IPs
# ============================================================
ip_nginx: {{ ip_nginx | default('10.255.0.10') }}
ip_bind9: {{ ip_bind9 | default('10.255.0.30') }}
ip_stepca: {{ ip_stepca | default('10.255.0.40') }}
ip_ldap: {{ ip_ldap | default('10.255.0.50') }}
ip_keycloak: {{ ip_keycloak | default('10.255.0.60') }}
ip_postgres: {{ ip_postgres | default('10.255.0.70') }}

# ============================================================
# SERVICE HOSTNAMES
# ============================================================
cname_ca: {{ cname_ca | default('ca') }}
certificate_land_page_cname: '{{ certificate_land_page_cname | default('') }}'
cname_dns: {{ cname_dns | default('dns') }}
cname_ldap: {{ cname_ldap | default('ldap') }}
cname_sso: {{ cname_sso | default('sso') }}

hostname_nginx: {{ hostname_nginx | default('nginx.' ~ domain) }}
hostname_bind9: {{ hostname_bind9 | default((cname_dns | default('dns')) ~ '.' ~ domain) }}
hostname_stepca: {{ hostname_stepca | default((cname_ca | default('ca')) ~ '.' ~ domain) }}
hostname_certs: {{ hostname_certs | default((certificate_land_page_cname ~ '.' ~ domain) if certificate_land_page_cname | default('') else domain) }}
hostname_ldap: {{ hostname_ldap | default((cname_ldap | default('ldap')) ~ '.' ~ domain) }}
hostname_keycloak: {{ hostname_keycloak | default((cname_sso | default('sso')) ~ '.' ~ domain) }}

# ============================================================
# DOCKER IMAGES
# ============================================================
image_nginx: {{ image_nginx | default('nginx:latest') }}
image_bind9: {{ image_bind9 | default('ubuntu/bind9:latest') }}
image_stepca: {{ image_stepca | default('smallstep/step-ca:latest') }}
image_openldap: {{ image_openldap | default('osixia/openldap:latest') }}
image_keycloak: {{ image_keycloak | default('keycloak/keycloak:latest') }}
image_postgres: {{ image_postgres | default('postgres:latest') }}

install_ldap: {{ install_ldap | default(true) | bool }}
install_keycloak: {{ install_keycloak | default(false) | bool }}
enforce_ldaps: {{ enforce_ldaps | default(true) | bool }}
bind9_dns_resolver: {{ bind9_dns_resolver | default(true) | bool }}

# ============================================================
# DOCKER / SERVICE INFRASTRUCTURE
# ============================================================
compose_file: {{ compose_file | default((deploy_base_dir | default('/opt')) ~ '/core/docker-compose.yml') }}
project_containers:
{{ project_containers | default(['nginx', 'step-ca', 'bind9']) | to_nice_yaml(indent=2) | indent(2, first=True) }}{% if install_ldap | default(false) | bool %}
  - openldap
{% endif %}{% if install_keycloak | default(false) | bool %}
  - keycloak
  - postgres
{% endif %}
{% set default_service_dirs = [
  { 'folder': 'nginx', 'owner': 'nginx' },
  { 'folder': 'bind9', 'owner': 'bind' },
  { 'folder': 'stepca', 'owner': 'step' },
  { 'folder': 'openldap', 'owner': 'ldap' },
  { 'folder': 'keycloak', 'owner': 'keycloak' },
  { 'folder': 'postgres', 'owner': 'postgres' }
] %}
service_dirs:
{{ service_dirs | default(default_service_dirs) | to_nice_yaml(indent=2) | indent(2, first=True) }}
{% set default_service_users = {
  'bind': {'uid': 53, 'gid': 53},
  'ldap': {'uid': 911, 'gid': 911},
  'nginx': {'uid': 443, 'gid': 443},
  'step': {'uid': 135, 'gid': 135},
  'keycloak': {'uid': 900, 'gid': 0},
  'postgres': {'uid': 901, 'gid': 901}
} %}
service_users:
{{ service_users | default(default_service_users) | to_nice_yaml(indent=2) | indent(2, first=True) }}

# ============================================================
# CERTIFICATES / PKI
# ============================================================
byoc: {{ byoc | default(false) }}
root_cert_name: {{ root_cert_name | default('root_ca') }}
ca_crt_path: {{ ca_crt_path | default('/home/default_admin/output/root_ca.crt') }}
ica_crt_path: {{ ica_crt_path | default('/home/default_admin/output/ica.crt') }}
{% if ica_key_path is defined and ica_key_path | length > 0 %}
ica_key_path: {{ ica_key_path }}
{% endif %}
ca_name: {{ ca_name | default(friendly_name ~ ' CA') }}
cert_country: {{ cert_country | default('US') }}
cert_province: {{ cert_province | default('State') }}
cert_city: {{ cert_city | default('City') }}
cert_org: {{ cert_org | default(friendly_name) }}
cert_ou: {{ cert_ou | default('IT') }}
cert_root_ca_days: {{ cert_root_ca_days | default(1825) }}
cert_root_digest: {{ cert_root_digest | default('sha512') }}
cert_root_key_type: {{ cert_root_key_type | default('rsa') }}
cert_root_key_param: '{{ cert_root_key_param | default('4096') }}'
cert_intermediate_days: {{ cert_intermediate_days | default(1095) }}
cert_intermediate_digest: {{ cert_intermediate_digest | default('sha512') }}
cert_intermediate_key_type: {{ cert_intermediate_key_type | default('rsa') }}
cert_intermediate_key_param: '{{ cert_intermediate_key_param | default('4096') }}'
cert_service_days: {{ cert_service_days | default(365) }}

# ============================================================
# STEP-CA
# ============================================================
stepca_port: {{ stepca_port | default(9000) }}
stepca_cert_allow_subordinate_ca: {{ stepca_cert_allow_subordinate_ca | default(true) | lower }}
stepca_cert_max_lifetime_hours: {{ stepca_cert_max_lifetime_hours | default((cert_service_days | default(365) * 24) ~ 'h') }}
cert_acme_lifetime_hours: {{ cert_acme_lifetime_hours | default('720h') }}

# ============================================================
# DNS — BIND9
# ============================================================
bind_dns_port: {{ bind_dns_port | default(5353) }}
bind9_doh_port: {{ bind9_doh_port | default(8053) }}
{% set _core_subnet = core_subnet | default('10.255.0.0/24') %}
{% set default_acls = {
  'acme-updaters': [_core_subnet],
  'dns-resolvers': ['127.0.0.1', lan_cidr, _core_subnet]
} %}
{% set final_bind_acls = default_acls %}
{% if bind_acls is defined %}
  {% for k, v in bind_acls.items() %}
    {% set filtered_v = [] %}
    {% for item in v %}
      {% if item == '{{ core_subnet }}' %}
        {% set _ = filtered_v.append(_core_subnet) %}
      {% else %}
        {% set _ = filtered_v.append(item) %}
      {% endif %}
    {% endfor %}
    {% if k in final_bind_acls %}
      {% set _ = final_bind_acls.update({k: (final_bind_acls[k] + filtered_v) | unique | list}) %}
    {% else %}
      {% set _ = final_bind_acls.update({k: filtered_v}) %}
    {% endif %}
  {% endfor %}
{% endif %}
bind_acls:
{{ final_bind_acls | to_nice_yaml(indent=2) | indent(2, first=True) }}
{% set default_cnames = [
  { 'canonical': hostname, 'name': cname_ca | default('ca') },
  { 'canonical': hostname, 'name': cname_dns | default('dns') },
  { 'canonical': hostname, 'name': cname_ldap | default('ldap') },
  { 'canonical': hostname, 'name': cname_sso | default('sso') }
] %}
{% if certificate_land_page_cname | default('') %}
{% set _ = default_cnames.append({ 'canonical': hostname, 'name': certificate_land_page_cname }) %}
{% endif %}
{% set default_a = [
  { 'ip': host_ip, 'name': hostname }
] %}
{% if not certificate_land_page_cname | default('') %}
{% set _ = default_a.append({ 'ip': host_ip, 'name': '@' }) %}
{% endif %}
{% set _user_dns = dns | default({'dynamic_zone_var': {'zone_authority': true}}) %}
{% set _dynamic_zone = _user_dns.get('dynamic_zone_var', {}) %}
{% set _merged_a = (_dynamic_zone.get('A', []) + default_a) | unique | list %}
{% set _merged_cname = (_dynamic_zone.get('CNAME', []) + default_cnames) | unique | list %}
{% set _ = _dynamic_zone.update({'A': _merged_a, 'CNAME': _merged_cname}) %}
{% set _ = _user_dns.update({'dynamic_zone_var': _dynamic_zone}) %}
dns:
{% for zone_key, zone_records in _user_dns.items() %}
{% set zone_name = domain if zone_key == 'dynamic_zone_var' else zone_key %}
  {{ zone_name }}:
{{ zone_records | to_nice_yaml(indent=4) | indent(4, first=True) }}
{% endfor %}
tsig_keys:
{{ tsig_keys | to_nice_yaml(indent=2) | indent(2, first=True) }}

# ============================================================
# REVERSE DNS — auto-computed from A records in the dns: block
# ============================================================
reverse_zone_names:
{{ _user_dns.values() |
   selectattr('A', 'defined') |
   map(attribute='A') |
   flatten |
   map(attribute='ip') |
   select('match', '^\d+\.\d+\.\d+\.\d+$') |
   map('regex_replace', '^(\d+)\.(\d+)\.(\d+)\.\d+$', '\3.\2.\1.in-addr.arpa') |
   unique |
   list |
   to_nice_yaml(indent=2) |
   indent(2, first=True) }}
# ============================================================
# NGINX BACKENDS
# ============================================================
nginx_backend_ldap: {{ nginx_backend_ldap | default('openldap:389') }}
nginx_backend_stepca: {{ nginx_backend_stepca | default('https://step-ca:' ~ (stepca_port | default(9000))) }}

# ============================================================
# LDAP / OPENLDAP — base DN computed from domain
# ============================================================
ldap_base_dn: {{ domain.split('.') | map('regex_replace', '^', 'dc=') | join(',') }}
ldap_domain_components:
{{ domain.split('.') | to_nice_yaml(indent=2) | indent(2, first=True) }}

{% set default_ldap_groups = [
  { 'gidNumber': 1100, 'name': 'admins', 'permissions': ['read', 'write', 'modify'] },
  { 'gidNumber': 5000, 'name': 'users', 'permissions': ['read'] }
] %}
ldap_groups:
{{ ldap_groups | default(default_ldap_groups) | to_nice_yaml(indent=2) | indent(2, first=True) }}

{% set default_ldap_organizational_units = [
  { 'name': 'accounts', 'description': 'User Accounts' },
  { 'name': 'groups', 'description': 'Security Groups' },
  { 'name': 'admins', 'description': 'Privileged accounts', 'parent': 'accounts', 'uid_range': '1101-1999' },
  { 'name': 'users', 'description': 'Regular User accounts', 'parent': 'accounts', 'uid_range': '5001-50000' },
  { 'name': 'hosts', 'description': 'Computer objects', 'uid_range': '2000-4900' }
] %}
ldap_organizational_units:
{{ ldap_organizational_units | default(default_ldap_organizational_units) | to_nice_yaml(indent=2) | indent(2, first=True) }}
