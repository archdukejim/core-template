#!/bin/sh
# /etc/letsencrypt/renewal-hooks/deploy/core-hook.sh
# Generated via Jinja2 from vars.yml

# --- Variable Definitions ---
DOMAIN_NAME=$(basename "$RENEWED_LINEAGE")
ARCHIVE_PATH="/etc/letsencrypt/archive/$DOMAIN_NAME"

# UIDs from vars.yml
UID_NGINX={{ service_users.nginx.uid }}
UID_ADGUARD={{ service_users.adguard.uid }}
UID_BIND={{ service_users.bind.uid }}
UID_LDAP={{ service_users.ldap.uid }}

# URLs from vars.yml
URL_ADGUARD="{{ url_adguard }}"
URL_LDAP="{{ url_ldap }}"
URL_BIND9="{{ url_bind9 }}"

echo "[*] Updating permissions and reloading services for $DOMAIN_NAME..."

# 1. Global Nginx Permissions
# Nginx (UID $UID_NGINX) always needs read access to any issued certificate
setfacl -R -m u:${UID_NGINX}:rX "$ARCHIVE_PATH"

# 2. Service-Specific logic
case "$DOMAIN_NAME" in
    "$URL_ADGUARD")
        echo "[+] Applying AdGuard (UID ${UID_ADGUARD}) permissions..."
        setfacl -R -m u:${UID_ADGUARD}:rX "$ARCHIVE_PATH"
        docker restart adguard 2>/dev/null
        ;;
    "$URL_LDAP")
        echo "[+] Applying LDAP (UID ${UID_LDAP}) permissions..."
        setfacl -R -m u:${UID_LDAP}:rX "$ARCHIVE_PATH"
        docker restart openldap 2>/dev/null
        ;;
    "$URL_BIND9")
        echo "[+] Applying BIND9 (UID ${UID_BIND}) permissions..."
        setfacl -R -m u:${UID_BIND}:rX "$ARCHIVE_PATH"
        docker exec --workdir / bind9 rndc reload 2>/dev/null
        ;;
esac

# 3. Final Nginx reload
# Catch new symlink targets for the web server
docker exec --workdir / nginx nginx -s reload 2>/dev/null

echo "[+] Hooks for $DOMAIN_NAME completed."
