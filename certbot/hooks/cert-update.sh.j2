#!/bin/sh
# /etc/letsencrypt/renewal-hooks/deploy/cert-update.sh
# Rendered by Ansible from certbot/hooks/cert-update.sh.j2
# Version: {{ homecore_version }}

DOMAIN_NAME=$(basename "$RENEWED_LINEAGE")
RELAY_FIFO="/etc/letsencrypt/relay.fifo"

echo "[*] Triggering ACL relay and reloading services for $DOMAIN_NAME..."

# 1. Signal the host-side relay to apply ACLs (setfacl runs on the host, not in this container)
if [ -p "$RELAY_FIFO" ]; then
    echo "$DOMAIN_NAME" > "$RELAY_FIFO"
else
    echo "[!] Relay FIFO not found at $RELAY_FIFO — ACLs not updated. Is cert-relay.service running?"
fi

# 2. Reload/restart services
case "$DOMAIN_NAME" in
    "{{ url_adguard }}")
        docker restart adguardhome 2>/dev/null
        ;;
    "{{ url_ldap }}")
        docker restart openldap 2>/dev/null
        ;;
esac

# 3. Reload Nginx
docker exec --workdir / nginx nginx -s reload 2>/dev/null

echo "[+] Hooks for $DOMAIN_NAME completed."
