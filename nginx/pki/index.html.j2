<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ ca_name }} &mdash; PKI Certificates</title>
  <style>
    :root {
      --bg: #0f172a; --surface: #1e293b; --border: #334155;
      --text: #e2e8f0; --muted: #94a3b8; --accent: #38bdf8;
      --accent-hover: #7dd3fc; --green: #4ade80; --amber: #fbbf24;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      background: var(--bg); color: var(--text); line-height: 1.6;
      padding: 2rem 1rem; min-height: 100vh;
    }
    .container { max-width: 860px; margin: 0 auto; }
    h1 { font-size: 1.75rem; font-weight: 700; margin-bottom: .25rem; }
    .subtitle { color: var(--muted); margin-bottom: 2rem; }

    /* Chain diagram */
    .chain { display: flex; flex-direction: column; gap: 0; margin-bottom: 2.5rem; }
    .chain-node {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: .5rem; padding: 1.25rem 1.5rem;
      position: relative;
    }
    .chain-node + .chain-node { margin-top: -1px; border-top-left-radius: 0; border-top-right-radius: 0; }
    .chain-node:first-child + .chain-node { border-top-left-radius: 0; border-top-right-radius: 0; }
    .chain-node:not(:last-child) { border-bottom-left-radius: 0; border-bottom-right-radius: 0; }
    .chain-connector {
      width: 2px; height: 1.5rem; background: var(--border);
      margin-left: 2rem;
    }
    .chain-label {
      display: inline-block; font-size: .7rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: .05em; padding: .15rem .5rem;
      border-radius: .25rem; margin-bottom: .5rem;
    }
    .label-root { background: rgba(251,191,36,.15); color: var(--amber); }
    .label-intermediate { background: rgba(56,189,248,.15); color: var(--accent); }
    .label-leaf { background: rgba(74,222,128,.15); color: var(--green); }
    .chain-cn { font-size: 1.1rem; font-weight: 600; }
    .chain-meta { color: var(--muted); font-size: .85rem; margin-top: .25rem; }

    /* Cards */
    .card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: .5rem; padding: 1.5rem; margin-bottom: 1.5rem;
    }
    .card h2 { font-size: 1.15rem; margin-bottom: 1rem; }

    /* Download buttons */
    .downloads { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn {
      display: inline-flex; align-items: center; gap: .5rem;
      padding: .6rem 1.25rem; border-radius: .375rem;
      font-size: .9rem; font-weight: 500; text-decoration: none;
      transition: background .15s, color .15s;
    }
    .btn-primary { background: var(--accent); color: var(--bg); }
    .btn-primary:hover { background: var(--accent-hover); }
    .btn-secondary { background: var(--border); color: var(--text); }
    .btn-secondary:hover { background: #475569; }
    .btn svg { width: 1rem; height: 1rem; }

    /* Code blocks */
    pre {
      background: #0c1221; border: 1px solid var(--border); border-radius: .375rem;
      padding: 1rem; overflow-x: auto; font-size: .82rem; line-height: 1.5;
      color: var(--muted); margin-top: .75rem;
    }
    code { font-family: "SF Mono", "Fira Code", "Cascadia Code", monospace; }
    .cmd { color: var(--accent); }

    /* Tabs */
    .tabs { display: flex; gap: 0; margin-bottom: 0; }
    .tab {
      padding: .5rem 1rem; font-size: .85rem; cursor: pointer;
      background: transparent; border: 1px solid var(--border);
      border-bottom: none; color: var(--muted);
      border-radius: .375rem .375rem 0 0; margin-right: -1px;
    }
    .tab.active { background: var(--surface); color: var(--text); border-bottom-color: var(--surface); }
    .tab-content { display: none; }
    .tab-content.active { display: block; }
    .tab-panel {
      border: 1px solid var(--border); border-radius: 0 .375rem .375rem .375rem;
      padding: 1.25rem; background: var(--surface);
    }
    .tab-panel pre { margin-top: .5rem; }

    /* Subject table */
    .subject-table { width: 100%; border-collapse: collapse; font-size: .85rem; }
    .subject-table th { text-align: left; color: var(--muted); font-weight: 500; padding: .35rem .75rem .35rem 0; white-space: nowrap; }
    .subject-table td { padding: .35rem 0; }

    /* Footer */
    footer { text-align: center; color: var(--muted); font-size: .8rem; margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }

    @media (max-width: 600px) {
      body { padding: 1rem .75rem; }
      .downloads { flex-direction: column; }
      .btn { justify-content: center; }
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>{{ ca_name }}</h1>
    <p class="subtitle">{{ cert_org }} &mdash; Internal PKI Certificate Authority</p>

    <!-- Trust chain -->
    <div class="chain">
      <div class="chain-node">
        <span class="chain-label label-root">Root CA</span>
        <div class="chain-cn">{{ cert_org }} Root CA</div>
        <div class="chain-meta">Self-signed &bull; {{ cert_root_key_type | upper }} {{ cert_root_key_param }} &bull; {{ cert_root_ca_days // 365 }}-year validity</div>
      </div>
      <div class="chain-connector"></div>
      <div class="chain-node">
        <span class="chain-label label-intermediate">Intermediate CA</span>
        <div class="chain-cn">Intermediate CA</div>
        <div class="chain-meta">Signed by Root &bull; {{ cert_intermediate_key_type | upper }} {{ cert_intermediate_key_param }} &bull; {{ cert_intermediate_days // 365 }}-year validity</div>
      </div>
      <div class="chain-connector"></div>
      <div class="chain-node">
        <span class="chain-label label-leaf">Leaf Certificates</span>
        <div class="chain-cn">*.{{ domain }}</div>
        <div class="chain-meta">Issued via ACME or offline mint &bull; {{ cert_acme_lifetime_hours | replace('h','') | int // 24 }}-day default</div>
      </div>
    </div>

    <!-- Downloads -->
    <div class="card">
      <h2>Download Certificates</h2>
      <p style="color:var(--muted);font-size:.9rem;margin-bottom:1rem;">
        Install the <strong>Root CA</strong> certificate to trust all certificates issued by this PKI.
        The intermediate is included automatically in TLS chains served by internal services.
      </p>
      <div class="downloads">
        <a class="btn btn-primary" href="/pki/root_ca.crt" download>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
          Root CA Certificate
        </a>
        <a class="btn btn-secondary" href="/pki/intermediate_ca.crt" download>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
          Intermediate CA Certificate
        </a>
      </div>
    </div>

    <!-- Subject info -->
    <div class="card">
      <h2>Certificate Subject</h2>
      <table class="subject-table">
        <tr><th>Country (C)</th><td>{{ cert_country }}</td></tr>
        <tr><th>State (ST)</th><td>{{ cert_province }}</td></tr>
        <tr><th>Locality (L)</th><td>{{ cert_city }}</td></tr>
        <tr><th>Organization (O)</th><td>{{ cert_org }}</td></tr>
        <tr><th>Org Unit (OU)</th><td>{{ cert_ou }}</td></tr>
      </table>
    </div>

    <!-- Install instructions -->
    <div class="card">
      <h2>Install Root CA</h2>
      <p style="color:var(--muted);font-size:.9rem;margin-bottom:1rem;">
        After downloading, install the root certificate so your device trusts all internal services.
      </p>

      <div class="tabs">
        <div class="tab active" onclick="showTab(event,'tab-linux')">Linux</div>
        <div class="tab" onclick="showTab(event,'tab-macos')">macOS</div>
        <div class="tab" onclick="showTab(event,'tab-windows')">Windows</div>
        <div class="tab" onclick="showTab(event,'tab-ios')">iOS</div>
        <div class="tab" onclick="showTab(event,'tab-android')">Android</div>
      </div>
      <div class="tab-panel">
        <div id="tab-linux" class="tab-content active">
          <strong>Debian / Ubuntu:</strong>
          <pre><code><span class="cmd">wget</span> -q --no-check-certificate \
  https://ca.{{ domain }}/pki/root_ca.crt -O /tmp/{{ domain }}-root.crt
<span class="cmd">wget</span> -q --no-check-certificate \
  https://ca.{{ domain }}/pki/intermediate_ca.crt -O /tmp/{{ domain }}-intermediate.crt
<span class="cmd">sudo cp</span> /tmp/{{ domain }}-root.crt /usr/local/share/ca-certificates/{{ domain }}-root.crt
<span class="cmd">sudo cp</span> /tmp/{{ domain }}-intermediate.crt /usr/local/share/ca-certificates/{{ domain }}-intermediate.crt
<span class="cmd">sudo update-ca-certificates</span></code></pre>
          <strong style="display:block;margin-top:1rem;">RHEL / Fedora:</strong>
          <pre><code><span class="cmd">curl</span> -kso /tmp/{{ domain }}-root.crt https://ca.{{ domain }}/pki/root_ca.crt
<span class="cmd">curl</span> -kso /tmp/{{ domain }}-intermediate.crt https://ca.{{ domain }}/pki/intermediate_ca.crt
<span class="cmd">sudo cp</span> /tmp/{{ domain }}-root.crt /etc/pki/ca-trust/source/anchors/{{ domain }}-root.crt
<span class="cmd">sudo cp</span> /tmp/{{ domain }}-intermediate.crt /etc/pki/ca-trust/source/anchors/{{ domain }}-intermediate.crt
<span class="cmd">sudo update-ca-trust</span></code></pre>
          <p style="color:var(--muted);font-size:.8rem;margin-top:.75rem;">
            The <code>--no-check-certificate</code> (wget) and <code>-k</code> (curl) flags are needed for the initial download before the CA is trusted. They can be removed for subsequent downloads.
          </p>
        </div>
        <div id="tab-macos" class="tab-content">
          <strong>Download and install:</strong>
          <pre><code><span class="cmd">curl</span> -kso ~/Downloads/root_ca.crt https://ca.{{ domain }}/pki/root_ca.crt
<span class="cmd">curl</span> -kso ~/Downloads/intermediate_ca.crt https://ca.{{ domain }}/pki/intermediate_ca.crt
<span class="cmd">sudo security add-trusted-cert</span> -d -r trustRoot \
  -k /Library/Keychains/System.keychain ~/Downloads/root_ca.crt
<span class="cmd">sudo security add-trusted-cert</span> -d -r trustAsRoot \
  -k /Library/Keychains/System.keychain ~/Downloads/intermediate_ca.crt</code></pre>
          <p style="color:var(--muted);font-size:.85rem;margin-top:.75rem;">
            Or double-click each downloaded file, add to <em>System</em> keychain, then set trust to <em>Always Trust</em>.
          </p>
        </div>
        <div id="tab-windows" class="tab-content">
          <strong>Via PowerShell (Administrator):</strong>
          <pre><code><span class="cmd">Invoke-WebRequest</span> -Uri https://ca.{{ domain }}/pki/root_ca.crt `
  -OutFile $env:TEMP\root_ca.crt -SkipCertificateCheck
<span class="cmd">Invoke-WebRequest</span> -Uri https://ca.{{ domain }}/pki/intermediate_ca.crt `
  -OutFile $env:TEMP\intermediate_ca.crt -SkipCertificateCheck
<span class="cmd">Import-Certificate</span> -FilePath $env:TEMP\root_ca.crt `
  -CertStoreLocation Cert:\LocalMachine\Root
<span class="cmd">Import-Certificate</span> -FilePath $env:TEMP\intermediate_ca.crt `
  -CertStoreLocation Cert:\LocalMachine\CA</code></pre>
          <p style="color:var(--muted);font-size:.85rem;margin-top:.75rem;">
            The root goes into <em>Trusted Root Certification Authorities</em> and the intermediate into <em>Intermediate Certification Authorities</em>.
            Or double-click each file &rarr; <em>Install Certificate</em> &rarr; <em>Local Machine</em> &rarr; select the appropriate store.
          </p>
        </div>
        <div id="tab-ios" class="tab-content">
          <ol style="color:var(--muted);font-size:.85rem;padding-left:1.25rem;">
            <li>Open Safari and navigate to <code>https://ca.{{ domain }}/pki/root_ca.crt</code></li>
            <li>Tap <strong>Allow</strong> when prompted to download the profile</li>
            <li>Go to <strong>Settings &rarr; General &rarr; VPN &amp; Device Management</strong> and install the profile</li>
            <li>Return to Safari and navigate to <code>https://ca.{{ domain }}/pki/intermediate_ca.crt</code></li>
            <li>Tap <strong>Allow</strong> and install this profile the same way</li>
            <li>Go to <strong>Settings &rarr; General &rarr; About &rarr; Certificate Trust Settings</strong></li>
            <li>Enable full trust for <em>{{ cert_org }} Root CA</em></li>
          </ol>
        </div>
        <div id="tab-android" class="tab-content">
          <ol style="color:var(--muted);font-size:.85rem;padding-left:1.25rem;">
            <li>Open Chrome and navigate to <code>https://ca.{{ domain }}/pki/root_ca.crt</code></li>
            <li>Go to <strong>Settings &rarr; Security &rarr; Encryption &amp; credentials</strong></li>
            <li>Tap <strong>Install a certificate &rarr; CA certificate</strong> and select the root file</li>
            <li>Return to Chrome and navigate to <code>https://ca.{{ domain }}/pki/intermediate_ca.crt</code></li>
            <li>Repeat the install steps for the intermediate certificate</li>
          </ol>
          <p style="color:var(--muted);font-size:.8rem;margin-top:.75rem;">
            Note: Android user-installed CAs are only trusted by apps that opt in. System-level trust requires a rooted device.
          </p>
        </div>
      </div>
    </div>

    <footer>
      {{ ca_name }} &bull; {{ hostname_stepca }} &bull; Served by Step-CA + Nginx
    </footer>
  </div>

  <script>
    function showTab(e, id) {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      e.target.classList.add('active');
      document.getElementById(id).classList.add('active');
    }
  </script>
</body>
</html>
