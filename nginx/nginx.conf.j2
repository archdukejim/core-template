{# ----------------------------------------------------------------- #}
{# nginx.conf — rendered by Ansible from nginx/nginx.conf.j2         #}
{# Version: {{ homecore_version }}                                    #}
{# ----------------------------------------------------------------- #}

# Global settings
worker_processes  auto;
worker_rlimit_nofile 65535;
error_log  /var/log/nginx/error.log notice;
pid        /tmp/nginx.pid;

events {
    multi_accept on;
    worker_connections  16384;
}

# DNS / LDAP stream proxies
stream {
    resolver 127.0.0.11 valid=30s;

    # DNS - UDP (nginx proxies port 53 → AdGuard in full mode, BIND9 in bind9-only mode)
    server {
        listen 53 udp reuseport;
        proxy_pass {% if bind9_only | default(false) %}bind9:{{ bind_dns_port }}{% else %}{{ nginx_backend_adguard_dns }}{% endif %};
        proxy_responses 1;
        proxy_timeout 1s;
        proxy_buffer_size 16k;
    }

    # DNS - TCP
    server {
        listen 53;
        proxy_pass {% if bind9_only | default(false) %}bind9:{{ bind_dns_port }}{% else %}{{ nginx_backend_adguard_dns }}{% endif %};
        proxy_timeout 3s;
    }

    # DNS over TLS — nginx terminates TLS, forwards plain DNS to backend
    server {
        listen 853 ssl;
        proxy_pass {% if bind9_only | default(false) %}bind9:{{ bind_dns_port }}{% else %}{{ nginx_backend_adguard_dns }}{% endif %};
        ssl_certificate     /etc/letsencrypt/live/{% if bind9_only | default(false) %}{{ hostname_bind9 }}{% else %}{{ hostname_adguard }}{% endif %}/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/{% if bind9_only | default(false) %}{{ hostname_bind9 }}{% else %}{{ hostname_adguard }}{% endif %}/privkey.pem;
        ssl_protocols       TLSv1.2 TLSv1.3;
        proxy_timeout 10s;
    }

    # LDAP - plain TCP
    server {
        listen 389;
        set $ldap_backend "{{ nginx_backend_ldap }}";
        proxy_pass $ldap_backend;
        proxy_timeout 10s;
        proxy_connect_timeout 5s;
    }

    # LDAPS — nginx terminates TLS, forwards plain LDAP to backend
    server {
        listen 636 ssl;
        set $ldaps_backend "{{ nginx_backend_ldap }}";
        proxy_pass $ldaps_backend;
        ssl_certificate     /etc/letsencrypt/live/{{ hostname_ldap }}/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/{{ hostname_ldap }}/privkey.pem;
        ssl_protocols       TLSv1.2 TLSv1.3;
        proxy_timeout 10s;
        proxy_connect_timeout 5s;
    }
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    # Non-root user (UID {{ service_users.nginx.uid }}) temp paths
    client_body_temp_path /tmp/client_temp;
    proxy_temp_path       /tmp/proxy_temp;
    fastcgi_temp_path     /tmp/fastcgi_temp;
    uwsgi_temp_path       /tmp/uwsgi_temp;
    scgi_temp_path        /tmp/scgi_temp;

    resolver 127.0.0.11 valid=30s;

    # HTTP — health check, ACME passthrough, redirect everything else to HTTPS
    server {
        listen 80 default_server;
        server_name _;

        location /health {
            access_log off;
            return 200 'OK';
        }

        location ^~ /.well-known/acme-challenge/ {
            root /var/www/certbot;
            allow all;
        }

        location / {
            return 301 https://$host$request_uri;
        }
    }

{% if bind9_only | default(false) %}
    # HTTPS — DNS-over-HTTPS via BIND9 (bind9-only mode)
    # nginx terminates TLS; BIND9 serves plain HTTP DoH on port {{ bind9_doh_port }}.
    server {
        listen 443 ssl;
        server_name {{ hostname_bind9 }};

        ssl_certificate     /etc/letsencrypt/live/{{ hostname_bind9 }}/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/{{ hostname_bind9 }}/privkey.pem;
        ssl_protocols       TLSv1.2 TLSv1.3;

        location /dns-query {
            proxy_pass http://bind9:{{ bind9_doh_port }};
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_http_version 1.1;
        }
    }
{% endif %}

{% if not bind9_only | default(false) %}
    # HTTPS — AdGuard Home UI + DNS-over-HTTPS (full mode)
    server {
        listen 443 ssl;
        server_name {{ hostname_adguard }};

        ssl_certificate     /etc/letsencrypt/live/{{ hostname_adguard }}/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/{{ hostname_adguard }}/privkey.pem;
        ssl_protocols       TLSv1.2 TLSv1.3;

        set $adguard_backend "{{ nginx_backend_adguard_http }}";

        location / {
            proxy_pass $adguard_backend;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            proxy_buffers 8 16k;
            proxy_buffer_size 32k;
        }

        location /dns-query {
            proxy_pass $adguard_backend;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }
{% endif %}

    # Step-CA — pass HTTPS through to Step-CA's native TLS on port {{ stepca_port }}
    server {
        listen 443 ssl;
        server_name {{ hostname_stepca }};

        ssl_certificate     /etc/letsencrypt/live/{{ hostname_stepca }}/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/{{ hostname_stepca }}/privkey.pem;
        ssl_protocols       TLSv1.2 TLSv1.3;

        set $stepca_backend "{{ nginx_backend_stepca }}";

        # PKI info page and certificate downloads
        location = /pki {
            return 301 /pki/;
        }
        location = /pki/ {
            alias /srv/pki/;
            index index.html;
        }
        location = /pki/index.html {
            alias /srv/pki/index.html;
        }
        location = /pki/root_ca.crt {
            alias /srv/pki/certs/root_ca.crt;
            default_type application/x-pem-file;
            add_header Content-Disposition 'attachment; filename="root_ca.crt"';
        }
        location = /pki/intermediate_ca.crt {
            alias /srv/pki/certs/intermediate_ca.crt;
            default_type application/x-pem-file;
            add_header Content-Disposition 'attachment; filename="intermediate_ca.crt"';
        }

        location / {
            proxy_pass $stepca_backend;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_ssl_verify off;
        }
    }
}
